<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                50: '#f4f9f0',
                100: '#dceccd',
                200: '#b9d69f',
                300: '#8ebf6b',
                400: '#6da545',
                500: '#4f8430',
                600: '#396523',
                700: '#2d4f1d',
                800: '#213a16',
                900: '#182a0f'
              },
              accent: {
                50: '#fff8e9',
                100: '#ffe7b8',
                200: '#f7cc79',
                300: '#f0b448',
                400: '#e69a1b',
                500: '#c97a10',
                600: '#9a5910',
                700: '#75440c',
                800: '#4d2e08',
                900: '#2c1a05'
              }
            },
            boxShadow: {
              soft: '0 20px 60px rgba(15, 23, 42, 0.12)'
            }
          }
        }
      };
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-900 antialiased">
    <header class="sticky top-0 z-40 border-b border-white/10 bg-slate-950/90 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="#top" class="flex items-center gap-3">
          <img src="../../images/logo.jpeg" alt="Garden and Landscaping Pros logo" class="h-12 w-12 rounded-2xl object-cover shadow-soft" />
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-white">Garden & Landscaping Pros</p>
            <p class="text-xs text-slate-400">Modern outdoor design</p>
          </div>
        </a>
        <nav class="hidden items-center gap-6 text-sm font-medium text-slate-300 md:flex">
          <a href="#services" class="transition hover:text-white">Services</a>
          <a href="#portfolio" class="transition hover:text-white">Portfolio</a>
          <a href="#quote" class="transition hover:text-white">Quote</a>
        </nav>
        <a href="#quote" class="rounded-full bg-accent-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-accent-400">Book a quote</a>
      </div>
    </header>

    <main id="top">
      <section class="relative overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-brand-950">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(109,165,69,0.28),_transparent_30%)]"></div>
        <div class="relative mx-auto grid max-w-7xl gap-10 px-4 py-20 sm:px-6 lg:grid-cols-[1.15fr_0.85fr] lg:px-8 lg:py-28">
          <div class="max-w-2xl">
            <p class="mb-4 inline-flex rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.28em] text-brand-100">Premium landscape services</p>
            <h1 class="text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl">Beautiful outdoor spaces, built to impress.</h1>
            <p class="mt-6 text-lg leading-8 text-slate-100">From custom garden design to full property upgrades, our team creates modern, functional landscapes that feel polished and welcoming.</p>
            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <a href="#quote" class="inline-flex items-center justify-center rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-accent-400">Request a free quote</a>
              <a href="#services" class="inline-flex items-center justify-center rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-slate-200 transition hover:border-brand-400 hover:text-white">Explore services</a>
            </div>
          </div>

          <div class="rounded-[2rem] border border-white/10 bg-white/10 p-6 shadow-soft backdrop-blur">
            <div class="rounded-[1.5rem] border border-white/10 bg-slate-900/95 p-6 shadow-2xl">
              <p class="text-sm font-semibold uppercase tracking-[0.26em] text-brand-200">How it works</p>
              <div class="mt-6 space-y-4">
                <div class="rounded-2xl border border-white/10 bg-white/10 p-4">
                  <p class="text-sm font-semibold text-white">1. Share your goals</p>
                  <p class="mt-1 text-sm text-slate-100">Tell us about the space, style, and timeline.</p>
                </div>
                <div class="rounded-2xl border border-white/10 bg-white/10 p-4">
                  <p class="text-sm font-semibold text-white">2. We prepare a tailored plan</p>
                  <p class="mt-1 text-sm text-slate-100">Your request is reviewed and structured for a quick response.</p>
                </div>
                <div class="rounded-2xl border border-white/10 bg-white/10 p-4">
                  <p class="text-sm font-semibold text-white">3. We follow up fast</p>
                  <p class="mt-1 text-sm text-slate-100">You receive direct communication and next steps.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <div class="max-w-2xl">
          <p class="mb-4 inline-flex rounded-full bg-brand-50 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.28em] text-brand-700">Services</p>
          <h2 class="text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">A polished service lineup for modern properties.</h2>
          <p class="mt-4 text-lg leading-8 text-slate-600">Swap in real photos later. For now, each card includes a clean placeholder so your service gallery is easy to update.</p>
        </div>

        <div class="mt-10 grid gap-6 lg:grid-cols-3">
          <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-soft">
            <div class="h-48 border-b border-slate-100 bg-[linear-gradient(135deg,_rgba(255,255,255,0.95),_rgba(221,241,207,0.95))] p-5">
              <div class="flex h-full flex-col items-center justify-center rounded-[1.25rem] border-2 border-dashed border-brand-200 bg-white/80 text-center text-sm font-medium text-slate-500">
                <span class="text-lg font-semibold text-brand-700">Add landscaping photo</span>
                <span class="mt-2 text-slate-400">Placeholder for a real service image</span>
              </div>
            </div>
            <div class="p-6">
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">Garden design</p>
              <h3 class="mt-3 text-xl font-semibold text-slate-950">Custom planting plans</h3>
              <p class="mt-3 text-slate-600">Creative layout strategies for curb appeal, seasonal color, and effortless flow.</p>
            </div>
          </article>

          <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-soft">
            <div class="h-48 border-b border-slate-100 bg-[linear-gradient(135deg,_rgba(255,255,255,0.95),_rgba(246,228,189,0.95))] p-5">
              <div class="flex h-full flex-col items-center justify-center rounded-[1.25rem] border-2 border-dashed border-accent-200 bg-white/80 text-center text-sm font-medium text-slate-500">
                <span class="text-lg font-semibold text-accent-700">Add patio photo</span>
                <span class="mt-2 text-slate-400">Placeholder for a real service image</span>
              </div>
            </div>
            <div class="p-6">
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">Hardscaping</p>
              <h3 class="mt-3 text-xl font-semibold text-slate-950">Patios, pathways & features</h3>
              <p class="mt-3 text-slate-600">Modern structures and clean finishes that bring function and style together.</p>
            </div>
          </article>

          <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-soft">
            <div class="h-48 border-b border-slate-100 bg-[linear-gradient(135deg,_rgba(255,255,255,0.95),_rgba(224,242,217,0.95))] p-5">
              <div class="flex h-full flex-col items-center justify-center rounded-[1.25rem] border-2 border-dashed border-brand-200 bg-white/80 text-center text-sm font-medium text-slate-500">
                <span class="text-lg font-semibold text-brand-700">Add maintenance photo</span>
                <span class="mt-2 text-slate-400">Placeholder for a real service image</span>
              </div>
            </div>
            <div class="p-6">
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">Lawn care</p>
              <h3 class="mt-3 text-xl font-semibold text-slate-950">Maintenance & seasonal refresh</h3>
              <p class="mt-3 text-slate-600">Reliable upkeep that keeps every detail looking sharp year-round.</p>
            </div>
          </article>
        </div>
      </section>

      <section id="portfolio" class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
        <div class="rounded-[2rem] border border-slate-200 bg-slate-900 p-8 text-white shadow-soft">
          <p class="mb-4 inline-flex rounded-full bg-white/10 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.28em] text-brand-100">Portfolio</p>
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Recent work with a premium, modern feel.</h2>
          <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-300">Every project is designed to feel elevated, effortless, and tailored to the way clients actually live outdoors.</p>
        </div>
      </section>

      <section id="quote" class="mx-auto max-w-7xl px-4 pb-24 sm:px-6 lg:px-8">
        <div class="grid gap-8 rounded-[2rem] border border-slate-200 bg-white p-8 shadow-soft lg:grid-cols-[0.95fr_1.05fr] lg:p-10">
          <div class="space-y-5">
            <p class="inline-flex rounded-full bg-brand-50 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.28em] text-brand-700">Contact form</p>
            <h2 class="text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">Request a quote that lands in your inbox.</h2>
            <p class="text-lg leading-8 text-slate-600">The form below collects your details, validates the information, and sends a structured email to your account.</p>
            <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-5">
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">What you’ll receive</p>
              <ul class="mt-3 space-y-2 text-sm text-slate-600">
                <li>• Your client’s name, contact details, and property address</li>
                <li>• The service requested and full project notes</li>
                <li>• A clean email format ready for quick follow-up</li>
              </ul>
            </div>
          </div>

          <form id="quote-form" class="space-y-4 rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700" for="name">Full name</label>
                <input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" id="name" name="name" type="text" placeholder="Your name" required />
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700" for="email">Email</label>
                <input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" id="email" name="email" type="email" placeholder="you@example.com" required />
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700" for="phone">Phone</label>
                <input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" id="phone" name="phone" type="tel" placeholder="(555) 123-4567" required />
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700" for="address">Property address</label>
                <input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" id="address" name="address" type="text" placeholder="Street, city, state" required />
              </div>
            </div>

            <div>
              <label class="mb-2 block text-sm font-semibold text-slate-700" for="service">Service needed</label>
              <select class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" id="service" name="service" required>
                <option value="">Select a service</option>
                <option>Landscape design</option>
                <option>Planting & garden beds</option>
                <option>Hardscaping</option>
                <option>Maintenance & cleanup</option>
                <option>Other</option>
              </select>
            </div>

            <div>
              <label class="mb-2 block text-sm font-semibold text-slate-700" for="details">Project details</label>
              <textarea class="min-h-[150px] w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" id="details" name="details" rows="5" placeholder="Tell us about the property, goals, and timeline"></textarea>
            </div>

            <div id="form-message" class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700" aria-live="polite"></div>

            <button type="submit" class="w-full rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-accent-400">Send quote request</button>
          </form>
        </div>
      </section>
    </main>

    <footer class="border-t border-slate-200 bg-white/80">
      <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-8 text-sm text-slate-600 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
        <div class="flex items-center gap-3">
          <img src="/images/G%26L.png.JPEG" alt="Garden and Landscaping Pros logo" class="h-10 w-10 rounded-2xl object-cover" />
          <p class="font-semibold text-slate-700">Garden & Landscaping Pros</p>
        </div>
    </footer>

    <script src="/script.js"></script>
  </body>
</html>
